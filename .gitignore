# secrets
firebase-auth.js
# --------------------- #
# mobile app .gitignore #
# --------------------- #

# dependencies
mobileBudgeting/node_modules/

# Expo
mobileBudgeting/.expo/
mobileBudgeting/dist/
mobileBudgeting/web-build/
mobileBudgeting/expo-env.d.ts

# Native
mobileBudgeting/.kotlin/
mobileBudgeting/*.orig.*
mobileBudgeting/*.jks
mobileBudgeting/*.p8
mobileBudgeting/*.p12
mobileBudgeting/*.key
mobileBudgeting/*.mobileprovision

# Metro
mobileBudgeting/.metro-health-check*

# debug
mobileBudgeting/npm-debug.*
mobileBudgeting/yarn-debug.*
mobileBudgeting/yarn-error.*

# macOS
mobileBudgeting/.DS_Store
mobileBudgeting/*.pem

# local env files
mobileBudgeting/.env*.local

# typescript
mobileBudgeting/*.tsbuildinfo

# generated native folders
mobileBudgeting/ios
mobileBudgeting/android

# own additions
mobileBudgeting/.vscode/*
mobileBudgeting/!.vscode/extensions.json

# ---------------- #
# webapp gitignore #
# ---------------- #

