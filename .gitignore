webapp/logs
webapp/*.log
webapp/npm-debug.log*
webapp/yarn-debug.log*
webapp/yarn-error.log*
webapp/pnpm-debug.log*
webapp/lerna-debug.log*

webapp/node_modules
webapp/dist
webapp/dist-ssr
webapp/*.local

# Editor directories and files
webapp/.vscode/*
webapp/!.vscode/extensions.json
webapp/.idea
webapp/.DS_Store
webapp/*.suo
webapp/*.ntvs*
webapp/*.njsproj
webapp/*.sln
webapp/*.sw?
